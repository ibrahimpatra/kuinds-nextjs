# .env.local — Copy this file and fill in your Firebase credentials
# NEVER commit this file to GitHub (it's already in .gitignore)

# Firebase (get these from Firebase Console > Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin email (must match the Firebase Auth user you created)
NEXT_PUBLIC_ADMIN_EMAIL=admin@kuwaitindiadriving.com

# ImgBB API key for blog image uploads (free at imgbb.com)
NEXT_PUBLIC_IMGBB_API_KEY=your_imgbb_key_here
